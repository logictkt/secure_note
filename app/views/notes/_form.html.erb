<div class="note-form">
  <%= form_with model: note, class: "note-form__form" do |f| %>
    <% if note.errors.any? %>
      <div class="error-explanation">
        <ul>
          <% note.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="field">
      <%= f.label :title, "タイトル" %>
      <%= f.text_field :title, placeholder: "ノートのタイトル" %>
    </div>

    <div class="field">
      <%= f.label :body, "本文" %>
      <%= f.text_area :body, rows: 10, placeholder: "暗号化して保存されます" %>
    </div>

    <div class="note-form__actions">
      <%= f.submit "保存", class: "btn btn--primary" %>
      <%= link_to "キャンセル", notes_path, class: "btn btn--secondary" %>
    </div>
  <% end %>
</div>
