<h1>Home <small>(admin)</small></h1>

<nav>
  <% if authenticated? %>
    <p>ログイン中: <%= Current.user.email_address %></p>
    <%= button_to "ログアウト", session_path, method: :delete %>
  <% else %>
    <%= link_to "新規会員登録", new_registration_path %> |
    <%= link_to "ログイン", new_session_path %>
  <% end %>
</nav>

<hr>

<h2>管理者メニュー</h2>
<ul>
  <li><%= link_to "ユーザー一覧", users_path %></li>
  <li><%= link_to "ユーザー一覧 (.md)", users_path(format: :md) %></li>
</ul>

<hr>

<p>
  動作確認用リンク:<br>
  <%= link_to "default に戻る", root_path %> |
  <%= link_to "?admin=true&console=true", root_path(admin: true, console: true) %>
</p>
